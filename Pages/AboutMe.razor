@page "/AboutMe"

<main>

    <section class="tile-centered">
        <h1>Frédéric Larue</h1>
        <h2>Ingénieur logiciel Dev Ops</h2>
        <p>Développeur passionné basé à Troyes, à la recherche d'un poste en ingénierie logicielle.<br>Formé en DevOps
            et en développement full stack.</p>
            <div class="hero-actions">
                <a href="https://github.com/fredo71" target="_blank" class="svg-gradiant maximize-icon">
                    <i class="bi bi-github "></i>
                </a>
                <button class="btn-styled" onClick="document.getElementById('skills').scrollIntoView();">
